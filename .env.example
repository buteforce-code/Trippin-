# Copy to .env.local and fill in. The anon/publishable key is browser-safe (RLS enforces access).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Google Maps JS API key with billing enabled (Phase 5 — Trip route map).
VITE_GOOGLE_MAPS_API_KEY=
# Optional: a cloud-configured Map ID for custom map styling (defaults to DEMO_MAP_ID).
VITE_GOOGLE_MAPS_MAP_ID=
